<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport"content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">
    <title>Book an Appointment</title>
</head>
<body>
 <header>
    <h1>BrightSmile Dental Studio</h1>
 </header>
 <main>
 <section>

 <form>
 <label for="name">Name:</label>
        <input type="text" id="name" name="name">
    <label for="number">Phone Number:</label>
        <input type="number" id="number" name="number">
    <label for="email">Email:</label>
        <input type="email" id="email" name="email">

   <label for="appointment_type">How can we help you?</label>
   <select name="appointment_type" id="appointment_type">
   <option value="" disabled selected>Select an experience...</option>

   <!--Group 1: Essetial Care-->
   <optgroup label="Essential Wellness">
   <option value="Teeth Cleaning">Teeth Cleaning</option>
   <option value="Tooth Extraction">Tooth Extraction</option>
   <option value="Braces Consultation">Braces Consultation</option>
   <option value="Teeth Whitening">Teeth Whitening</option>
   </optgroup>

   <!--Group 2: Aestetic & Transformation-->
   <optgroup label="Smile Design & Aestetics">
   <option value="Teeth Whitening">Boutique Laser Whitening</option>
   <option value="Veneers">Signature Porcelain Veneers</option>
   <option value="Digital Smile Design">Digital Smile Design (3D Preview)</option>
   </optgroup>

   <!--Group 3: Specialised Care-->
   <optgroup label="Orthodontics & Alignment">
   <option value="Braces Consultation">Orthodontic & Invisalign Assessments</option>
   </optgroup>
   </select>

   <label for="message">Leave us a message!</label>
   <textarea id="message" name="message"></textarea>

   <input type="submit" value="Submit">

 </form>
 </section>

 <section>
 <div class="table_container">
    <table border="1">
        <thead>
            <tr>
                <th>Date</th>
                <th>Time</th>
                <th>Availability</th>
            </tr>
        </thead>
        <tbody>
